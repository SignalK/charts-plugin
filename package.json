{
  "name": "@signalk/charts-plugin",
  "version": "3.4.0",
  "description": "Signal K plugin to provide chart support for Signal K server",
  "main": "plugin/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rimraf plugin",
    "prebuild": "npm run clean",
    "watch": "npm run build -- -w",
    "start": "npm run build -- -w",
    "typecheck": "tsc --noEmit",
    "prettier:check": "prettier --check .",
    "prettier": "prettier --write .",
    "format": "npm run prettier",
    "test": "mocha",
    "coverage": "c8 --reporter=text --reporter=lcov npm test",
    "mutation": "stryker run",
    "prepublishOnly": "npm run build"
  },
  "license": "Apache-2.0",
  "keywords": [
    "signalk",
    "signalk-node-server-plugin",
    "signalk-webapp",
    "nautic",
    "chart",
    "mbtiles",
    "tms"
  ],
  "author": {
    "name": "Mikko Vesikkala",
    "email": "mikko.vesikkala@iki.fi"
  },
  "dependencies": {
    "@signalk/mbtiles": "0.1.1",
    "@signalk/server-api": "^2.0.0",
    "@turf/bbox": "^7.2.0",
    "@turf/boolean-intersects": "^7.2.0",
    "@turf/helpers": "^7.2.0",
    "check-disk-space": "^3.4.0",
    "fast-xml-parser": "^5.7.1",
    "geojson-antimeridian-cut": "^0.1.0",
    "lodash": "^4.17.11",
    "p-limit": "^3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/SignalK/charts-plugin"
  },
  "devDependencies": {
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/mocha-runner": "^9.6.1",
    "@types/chai": "^4.3.11",
    "@types/express": "^4.17.17",
    "@types/lodash": "^4.14.191",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.10.5",
    "c8": "^11.0.0",
    "chai": "4.1.2",
    "chai-http": "^4.2.1",
    "express": "^4.20.0",
    "mocha": "^11.7.1",
    "prettier": "^3.8.2",
    "rimraf": "^6.1.3",
    "tsx": "^4.20.3",
    "typescript": "^6.0.3"
  }
}
